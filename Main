<body>

<h1>ayoo main ayyyy</h1>

<button id="yes">Iya</button>
<button id="no">Tidak</button>

<script>
const yesBtn = document.getElementById("yes");
const noBtn = document.getElementById("no");

let noScale = 1;
let yesScale = 1;

function kabur() {
    // Tombol Tidak pindah
    const maxX = window.innerWidth - noBtn.offsetWidth;
    const maxY = window.innerHeight - noBtn.offsetHeight;

    noBtn.style.left = Math.random() * maxX + "px";
    noBtn.style.top = Math.random() * maxY + "px";

    // Tombol Tidak mengecil
    noScale *= 0.85;
    noBtn.style.transform = `scale(${noScale})`;

    // Tombol Iya membesar
    yesScale *= 1.15;
    yesBtn.style.transform = `scale(${yesScale})`;

    // Hilang kalau terlalu kecil
    if (noScale < 0.2) {
        noBtn.style.display = "none";
    }
}

noBtn.addEventListener("mouseover", kabur);
noBtn.addEventListener("click", kabur);

yesBtn.addEventListener("click", () => {
    document.body.innerHTML = `
        <h1 style="margin-top:150px;">
            🥳 YEAYYY!!<br><br>
            Makasih udah mau main 😆❤️
        </h1>
    `;
});
</script>

</body>
</html>
