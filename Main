<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ayo Main</title>

<style>
body{
    font-family: Arial, sans-serif;
    text-align:center;
    background:#f5f5f5;
    overflow:hidden;
    margin-top:150px;
}

h1{
    margin-bottom:40px;
}

button{
    border:none;
    border-radius:12px;
    cursor:pointer;
    transition:0.2s;
}

#yes{
    background:#4CAF50;
    color:white;
    font-size:20px;
    padding:15px 30px;
}

#no{
    background:#f44336;
    color:white;
    font-size:20px;
    padding:15px 30px;
    position:absolute;
    margin-left:20px;
}
</style>
